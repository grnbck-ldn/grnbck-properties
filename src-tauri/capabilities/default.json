{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "updater:default",
    "dialog:default",
    "fs:default",
    "fs:write-all",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://nominatim.openstreetmap.org/*" }
      ]
    }
  ]
}