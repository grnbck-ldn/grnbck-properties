{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "grnbck Properties",
  "version": "0.1.0",
  "identifier": "com.grnbck.properties",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "grnbck Properties",
        "width": 1200,
        "height": 780,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  }
}