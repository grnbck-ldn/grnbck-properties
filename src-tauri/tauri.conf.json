{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "grnbck London",
  "version": "1.1.0",
  "identifier": "com.yourcompany.grnbck.properties",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "grnbck London",
        "width": 1200,
        "height": 780,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyQzA2MTFCNEQwQzkyNEUKUldST2tneE5HMkhBY2lKUjF5NTVUVk9BWWhuMU5TVllrRzZ4VUJ4VHJaTTc4aytoUWE2dzRoT2cK",
      "endpoints": [
        "https://grnbck-ldn.github.io/grnbck-properties/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}